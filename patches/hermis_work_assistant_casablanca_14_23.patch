--- /dev/null
+++ b/apps/discord_tracker/work.py
@@ -0,0 +1,315 @@
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass
+from datetime import date, timedelta
+from typing import Any
+
+
+PRIORITIES = ("p0", "p1", "p2", "p3")
+STATUSES = ("open", "waiting", "blocked", "done", "cancelled")
+PRIORITY_LABELS = {
+    "p0": "urgent / must move now",
+    "p1": "important / next",
+    "p2": "normal / scheduled",
+    "p3": "backlog / someday",
+}
+WEEKDAYS = {
+    "mon": 0,
+    "monday": 0,
+    "tue": 1,
+    "tues": 1,
+    "tuesday": 1,
+    "wed": 2,
+    "wednesday": 2,
+    "thu": 3,
+    "thur": 3,
+    "thurs": 3,
+    "thursday": 3,
+    "fri": 4,
+    "friday": 4,
+    "sat": 5,
+    "saturday": 5,
+    "sun": 6,
+    "sunday": 6,
+}
+
+
+@dataclass(frozen=True)
+class WorkItemDraft:
+    title: str
+    priority: str = "p2"
+    status: str = "open"
+    project: str | None = None
+    area: str | None = None
+    due_date: str | None = None
+    energy: str | None = None
+    effort_minutes: int | None = None
+    context: str | None = None
+    tags: tuple[str, ...] = ()
+    note: str | None = None
+    confidence: str = "medium"
+    raw_text: str = ""
+
+
+def split_work_message(raw_text: str) -> list[str]:
+    """Split a Discord work message into task-like lines.
+
+    Empty lines are ignored. Common checkbox and bullet prefixes are stripped, so a
+    multiline capture can become multiple work items.
+    """
+    lines: list[str] = []
+    for raw_line in raw_text.splitlines():
+        line = raw_line.strip()
+        if not line:
+            continue
+        line = re.sub(r"^[-*•]\s+", "", line)
+        line = re.sub(r"^\[(?: |x|X)\]\s+", "", line)
+        if line:
+            lines.append(line)
+    return lines or ([raw_text.strip()] if raw_text.strip() else [])
+
+
+def should_capture_work_message(raw_text: str) -> bool:
+    text = raw_text.strip()
+    if not text or text.startswith("!"):
+        return False
+    lowered = text.lower()
+    if lowered.startswith(("note:", "journal:", "log:")):
+        return False
+    return True
+
+
+def parse_work_item(raw_text: str, today: date | None = None) -> WorkItemDraft:
+    today = today or date.today()
+    original = raw_text.strip()
+    text = original
+    lowered = text.lower()
+
+    status = _parse_status(lowered)
+    due_date = _parse_due_date(lowered, today)
+    priority = _parse_priority(lowered, due_date, today, status)
+    project = _parse_project(text)
+    area = _parse_named_token(text, "area")
+    energy = _parse_energy(lowered)
+    effort_minutes = _parse_effort_minutes(lowered)
+    context = _parse_context(text)
+    tags = tuple(dict.fromkeys(tag.lower() for tag in re.findall(r"(?<!\w)#([A-Za-z][\w-]*)", text)))
+
+    title = _clean_title(text)
+    if not title:
+        title = original
+    confidence = "high" if _has_explicit_signal(lowered) else "medium"
+    return WorkItemDraft(
+        title=title,
+        priority=priority,
+        status=status,
+        project=project,
+        area=area,
+        due_date=due_date,
+        energy=energy,
+        effort_minutes=effort_minutes,
+        context=context,
+        tags=tags,
+        confidence=confidence,
+        raw_text=original,
+    )
+
+
+def normalize_priority(value: str | None) -> str:
+    if not value:
+        return "p2"
+    token = value.strip().lower()
+    token = token.replace("priority", "").replace(":", "").strip()
+    if token in PRIORITIES:
+        return token
+    if token in {"0", "urgent", "critical", "now", "must"}:
+        return "p0"
+    if token in {"1", "high", "important", "next"}:
+        return "p1"
+    if token in {"2", "normal", "medium"}:
+        return "p2"
+    if token in {"3", "low", "backlog", "someday"}:
+        return "p3"
+    return "p2"
+
+
+def priority_rank(priority: str) -> int:
+    try:
+        return PRIORITIES.index(priority)
+    except ValueError:
+        return PRIORITIES.index("p2")
+
+
+def render_item_line(item: dict[str, Any]) -> str:
+    parts = [f"`{item['id']}`", item.get("priority", "p2").upper(), item.get("title", "")]
+    due = item.get("due_date")
+    if due:
+        parts.append(f"due {due}")
+    project = item.get("project")
+    if project:
+        parts.append(f"project:{project}")
+    status = item.get("status")
+    if status and status != "open":
+        parts.append(f"status:{status}")
+    return " — ".join(str(part) for part in parts if part)
+
+
+def render_items(title: str, items: list[dict[str, Any]]) -> str:
+    if not items:
+        return f"**{title}**\nNo matching work items."
+    lines = [f"**{title}**"]
+    lines.extend(f"- {render_item_line(item)}" for item in items)
+    return "\n".join(lines)
+
+
+def render_focus_plan(local_date: str, focus: list[dict[str, Any]], blocked: list[dict[str, Any]]) -> str:
+    lines = [f"**Work focus for {local_date}**"]
+    if focus:
+        lines.append("Pick one, finish it, then pick the next:")
+        for index, item in enumerate(focus, start=1):
+            lines.append(f"{index}. {render_item_line(item)}")
+    else:
+        lines.append("No open focus items. Add one with `!work add <task>`." )
+    if blocked:
+        lines.append("")
+        lines.append("Blocked / waiting:")
+        for item in blocked[:5]:
+            lines.append(f"- {render_item_line(item)}")
+    lines.append("")
+    lines.append("Rule: start with the first P0/P1 item that can be completed in one work block.")
+    return "\n".join(lines)
+
+
+def render_search_results(query: str, results: list[dict[str, Any]]) -> str:
+    if not results:
+        return f"No local Life OS context found for `{query}`."
+    lines = [f"**Local context for `{query}`**"]
+    for result in results:
+        lines.append(f"- `{result['path']}:{result['line']}` — {result['snippet']}")
+    return "\n".join(lines)
+
+
+def _parse_status(lowered: str) -> str:
+    if lowered.startswith(("blocked", "blocker")) or " blocked by " in lowered:
+        return "blocked"
+    if lowered.startswith(("waiting", "wait for", "follow up")) or " waiting for " in lowered:
+        return "waiting"
+    return "open"
+
+
+def _parse_priority(lowered: str, due_date: str | None, today: date, status: str) -> str:
+    explicit = re.search(r"\bpriority[:=]?\s*p?([0-3])\b|\bp([0-3])\b", lowered)
+    if explicit:
+        value = explicit.group(1) or explicit.group(2)
+        return f"p{value}"
+    if any(token in lowered for token in ("urgent", "asap", "right now", "must", "critical", "blocker")):
+        return "p0"
+    if any(token in lowered for token in ("important", "high priority", "next action", "mit")):
+        return "p1"
+    if any(token in lowered for token in ("someday", "backlog", "low priority", "nice to have")):
+        return "p3"
+    if status == "blocked":
+        return "p1"
+    if due_date:
+        due = date.fromisoformat(due_date)
+        if due <= today:
+            return "p0"
+        if due <= today + timedelta(days=1):
+            return "p1"
+    return "p2"
+
+
+def _parse_due_date(lowered: str, today: date) -> str | None:
+    iso = re.search(r"\b(?:due|by|deadline)[:\s]+(20\d{2}-\d{2}-\d{2})\b", lowered)
+    if iso:
+        return iso.group(1)
+    if re.search(r"\b(?:today|eod|end of day)\b", lowered):
+        return today.isoformat()
+    if re.search(r"\btomorrow\b", lowered):
+        return (today + timedelta(days=1)).isoformat()
+    in_days = re.search(r"\bin\s+(\d{1,2})\s+days?\b", lowered)
+    if in_days:
+        return (today + timedelta(days=int(in_days.group(1)))).isoformat()
+    weekday = re.search(r"\b(?:by|due|next)?\s*(mon(?:day)?|tue(?:s|sday)?|wed(?:nesday)?|thu(?:r|rs|rsday)?|fri(?:day)?|sat(?:urday)?|sun(?:day)?)\b", lowered)
+    if weekday:
+        key = weekday.group(1)
+        target = WEEKDAYS.get(key)
+        if target is not None:
+            delta = (target - today.weekday()) % 7
+            if delta == 0 and "next" in lowered:
+                delta = 7
+            return (today + timedelta(days=delta)).isoformat()
+    return None
+
+
+def _parse_project(text: str) -> str | None:
+    bracket = re.search(r"^\[([^\]]{1,60})\]", text.strip())
+    if bracket:
+        return bracket.group(1).strip()
+    named = _parse_named_token(text, "project")
+    return named
+
+
+def _parse_named_token(text: str, key: str) -> str | None:
+    match = re.search(rf"\b{re.escape(key)}[:=]([^#@|;]+)", text, flags=re.IGNORECASE)
+    if not match:
+        return None
+    value = match.group(1).strip()
+    value = re.split(r"\s{2,}|\sdue:|\spriority:|\sarea:|\sproject:", value, maxsplit=1, flags=re.IGNORECASE)[0]
+    return value.strip() or None
+
+
+def _parse_context(text: str) -> str | None:
+    match = re.search(r"(?<!\w)@([A-Za-z][\w-]*)", text)
+    return match.group(1).lower() if match else None
+
+
+def _parse_energy(lowered: str) -> str | None:
+    explicit = re.search(r"\benergy[:=]\s*(low|medium|med|high)\b", lowered)
+    if explicit:
+        value = explicit.group(1)
+        return "medium" if value == "med" else value
+    if "low energy" in lowered:
+        return "low"
+    if "high energy" in lowered or "deep work" in lowered:
+        return "high"
+    return None
+
+
+def _parse_effort_minutes(lowered: str) -> int | None:
+    explicit = re.search(r"\beffort[:=]\s*(\d{1,3})\s*(m|min|mins|minutes|h|hr|hrs|hours)?\b", lowered)
+    if explicit:
+        amount = int(explicit.group(1))
+        unit = explicit.group(2) or "m"
+        return amount * 60 if unit.startswith("h") else amount
+    match = re.search(r"\b(\d{1,3})\s*(m|min|mins|minutes|h|hr|hrs|hours)\b", lowered)
+    if not match:
+        return None
+    amount = int(match.group(1))
+    unit = match.group(2)
+    return amount * 60 if unit.startswith("h") else amount
+
+
+def _clean_title(text: str) -> str:
+    title = text.strip()
+    title = re.sub(r"^\[([^\]]{1,60})\]\s*", "", title)
+    title = re.sub(r"^(todo|task|work|next|mit|blocked|blocker|waiting|follow up)[:\s-]+", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\bpriority[:=]?\s*p?[0-3]\b|\bp[0-3]\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\b(?:due|by|deadline)[:\s]+20\d{2}-\d{2}-\d{2}\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\b(?:due|by|deadline)[:\s]+(?:today|tomorrow|mon(?:day)?|tue(?:s|sday)?|wed(?:nesday)?|thu(?:r|rs|rsday)?|fri(?:day)?|sat(?:urday)?|sun(?:day)?)\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\b(?:today|tomorrow|eod|end of day)\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\beffort[:=]\s*\d{1,3}\s*(?:m|min|mins|minutes|h|hr|hrs|hours)?\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\b\d{1,3}\s*(?:m|min|mins|minutes|h|hr|hrs|hours)\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\benergy[:=]\s*(?:low|medium|med|high)\b", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"\b(?:project|area)[:=][^#@|;]+", "", title, flags=re.IGNORECASE)
+    title = re.sub(r"(?<!\w)[#@][A-Za-z][\w-]*", "", title)
+    title = re.sub(r"\s+", " ", title)
+    return title.strip(" -:;|")
+
+
+def _has_explicit_signal(lowered: str) -> bool:
+    return any(
+        signal in lowered
+        for signal in ("todo", "task", "due", "priority", "p0", "p1", "p2", "p3", "urgent", "blocked")
+    )
diff --git a/apps/discord_tracker/work_store.py b/apps/discord_tracker/work_store.py
