+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import os
+import sqlite3
+from dataclasses import dataclass
+from datetime import date, timedelta
+from pathlib import Path
+
+
+@dataclass(frozen=True)
+class Config:
+    root: Path
+    db_path: Path
+
+
+def load_config() -> Config:
+    root = Path(os.environ.get("LIFEOS_ROOT", "/home/ubuntu/hermis-life-os")).expanduser()
+    db_path = Path(os.environ.get("TRACKER_DB", str(root / "data" / "lifeos_tracker.db"))).expanduser()
+    env_file = root / ".env.discord-tracker"
+    if env_file.exists():
+        for line in env_file.read_text(encoding="utf-8").splitlines():
+            stripped = line.strip()
+            if not stripped or stripped.startswith("#") or "=" not in stripped:
+                continue
+            key, value = stripped.split("=", 1)
+            if key.strip() == "TRACKER_DB":
+                db_path = Path(value.strip().strip('"')).expanduser()
+    return Config(root=root, db_path=db_path)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description="Write a daily work assistant review from tracker DB.")
+    parser.add_argument("day", nargs="?", default=date.today().isoformat(), help="Local date to summarize, default: today")
+    parser.add_argument("--output", default=None, help="Output markdown path, default: reports/work/YYYY-MM-DD.md")
+    return parser.parse_args()
+
+
+def table_exists(con: sqlite3.Connection, name: str) -> bool:
+    row = con.execute("SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = ?", (name,)).fetchone()
+    return row is not None
+
+
+def fetch_day(con: sqlite3.Connection, day: str) -> dict:
+    empty = {
+        "completed": [],
+        "created": [],
+        "open_focus": [],
+        "blocked": [],
+        "improvements": [],
+        "counts": {"open": 0, "waiting": 0, "blocked": 0, "done_today": 0},
+    }
+    if not table_exists(con, "work_items"):
+        return empty
+    con.row_factory = sqlite3.Row
+    today = date.fromisoformat(day)
+    soon = (today + timedelta(days=2)).isoformat()
+    completed = con.execute(
+        """
+        SELECT id, title, priority, project, due_date
+        FROM work_items
+        WHERE completed_at_utc LIKE ?
+        ORDER BY completed_at_utc ASC
+        """,
+        (f"{day}%",),
+    ).fetchall()
+    created = con.execute(
+        """
+        SELECT id, title, priority, project, due_date
+        FROM work_items
+        WHERE created_at_utc LIKE ?
+        ORDER BY created_at_utc ASC
+        """,
+        (f"{day}%",),
+    ).fetchall()
+    focus = con.execute(
+        """
+        SELECT id, title, priority, project, due_date, effort_minutes
+        FROM work_items
+        WHERE status = 'open' AND (priority IN ('p0', 'p1') OR due_date <= ?)
+        ORDER BY CASE priority WHEN 'p0' THEN 0 WHEN 'p1' THEN 1 WHEN 'p2' THEN 2 ELSE 3 END,
+                 CASE WHEN due_date IS NULL THEN 1 ELSE 0 END,
+                 due_date ASC,
+                 COALESCE(effort_minutes, 999) ASC
+        LIMIT 8
+        """,
+        (soon,),
+    ).fetchall()
+    blocked = con.execute(
+        """
+        SELECT id, title, status, priority, project, due_date
+        FROM work_items
+        WHERE status IN ('blocked', 'waiting')
+        ORDER BY updated_at_utc DESC
+        LIMIT 8
+        """
+    ).fetchall()
+    counts = {}
+    for status in ("open", "waiting", "blocked"):
+        counts[status] = con.execute("SELECT COUNT(*) FROM work_items WHERE status = ?", (status,)).fetchone()[0]
+    counts["done_today"] = len(completed)
+    improvements = []
+    if table_exists(con, "work_improvements"):
+        improvements = con.execute(
+            """
+            SELECT id, idea, status
+            FROM work_improvements
+            WHERE status = 'open'
+            ORDER BY created_at_utc DESC
+            LIMIT 8
+            """
+        ).fetchall()
+    return {
+        "completed": [dict(row) for row in completed],
+        "created": [dict(row) for row in created],
+        "open_focus": [dict(row) for row in focus],
+        "blocked": [dict(row) for row in blocked],
+        "improvements": [dict(row) for row in improvements],
+        "counts": counts,
+    }
+
+
+def item_line(row: dict) -> str:
+    due = f" due {row['due_date']}" if row.get("due_date") else ""
+    project = f" project:{row['project']}" if row.get("project") else ""
+    return f"- #{row['id']} [{row.get('priority', '').upper()}]{due}{project} — {row['title']}"
+
+
+def render(day: str, data: dict) -> str:
+    lines = [
+        f"# Work Review - {day}",
+        "",
+        "## Metrics",
+        f"- Completed today: {data['counts'].get('done_today', 0)}",
+        f"- Open: {data['counts'].get('open', 0)}",
+        f"- Waiting: {data['counts'].get('waiting', 0)}",
+        f"- Blocked: {data['counts'].get('blocked', 0)}",
+        "",
+        "## Completed Today",
+    ]
+    lines.extend(item_line(row) for row in data["completed"]) if data["completed"] else lines.append("- none")
+    lines.extend(["", "## Created Today"])
+    lines.extend(item_line(row) for row in data["created"]) if data["created"] else lines.append("- none")
+    lines.extend(["", "## Next Focus"])
+    lines.extend(item_line(row) for row in data["open_focus"]) if data["open_focus"] else lines.append("- none")
+    lines.extend(["", "## Blocked / Waiting"])
+    lines.extend(item_line(row) for row in data["blocked"]) if data["blocked"] else lines.append("- none")
+    lines.extend(["", "## Improvement Backlog"])
+    if data["improvements"]:
+        lines.extend(f"- improve:{row['id']} {row['idea']}" for row in data["improvements"])
+    else:
+        lines.append("- none")
+    lines.extend([
+        "",
+        "## End-of-Day Questions",
+        "- What should be clarified before the next work block?",
+        "- What repeated friction should become automation, a template, or a checklist?",
+        "",
+    ])
+    return "\n".join(lines)
+
+
+def main() -> int:
+    args = parse_args()
+    config = load_config()
+    day = date.fromisoformat(args.day).isoformat()
+    output = Path(args.output).expanduser() if args.output else config.root / "reports" / "work" / f"{day}.md"
+    if not config.db_path.exists():
+        raise SystemExit(f"tracker DB missing: {config.db_path}")
+    with sqlite3.connect(f"file:{config.db_path}?mode=ro", uri=True) as con:
+        data = fetch_day(con, day)
+    output.parent.mkdir(parents=True, exist_ok=True)
+    output.write_text(render(day, data), encoding="utf-8")
+    print(f"wrote work review: {output}")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
