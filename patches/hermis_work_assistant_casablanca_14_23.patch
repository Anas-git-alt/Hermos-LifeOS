+from __future__ import annotations
+
+import asyncio
+import tempfile
+import unittest
+from datetime import date
+from pathlib import Path
+
+import sys
+
+APP_DIR = Path(__file__).resolve().parents[1]
+sys.path.insert(0, str(APP_DIR))
+
+from work import parse_work_item, split_work_message
+from work_store import WorkStore
+
+
+class WorkParserTests(unittest.TestCase):
+    def test_parse_explicit_priority_due_project(self) -> None:
+        item = parse_work_item(
+            "todo: send client invoice priority:p1 due:2026-05-04 project:Acme @email #billing 20m",
+            today=date(2026, 5, 2),
+        )
+        self.assertEqual(item.title, "send client invoice")
+        self.assertEqual(item.priority, "p1")
+        self.assertEqual(item.due_date, "2026-05-04")
+        self.assertEqual(item.project, "Acme")
+        self.assertEqual(item.context, "email")
+        self.assertEqual(item.tags, ("billing",))
+        self.assertEqual(item.effort_minutes, 20)
+
+    def test_parse_urgent_today_as_p0(self) -> None:
+        item = parse_work_item("urgent fix production bug today project:Hermes", today=date(2026, 5, 2))
+        self.assertEqual(item.priority, "p0")
+        self.assertEqual(item.due_date, "2026-05-02")
+        self.assertEqual(item.project, "Hermes")
+
+    def test_multiline_split(self) -> None:
+        self.assertEqual(split_work_message("- task one\n- task two"), ["task one", "task two"])
+
+
+class WorkStoreTests(unittest.TestCase):
+    def test_create_done_and_state_snapshot(self) -> None:
+        async def run_case() -> None:
+            with tempfile.TemporaryDirectory() as tempdir:
+                root = Path(tempdir)
+                store = WorkStore(root / "tracker.db", root)
+                await store.init()
+                drafts = [parse_work_item("todo: send update due:2026-05-02 p1", today=date(2026, 5, 2))]
+                result = await store.log_work_message(
+                    local_date="2026-05-02",
+                    raw_text="todo: send update due:2026-05-02 p1",
+                    drafts=drafts,
+                    message_id=10,
+                    channel_id=20,
+                    channel_name="work-tracker",
+                    logged_by=30,
+                )
+                self.assertTrue(result["created"])
+                duplicate = await store.log_work_message(
+                    local_date="2026-05-02",
+                    raw_text="todo: send update due:2026-05-02 p1",
+                    drafts=drafts,
+                    message_id=10,
+                    channel_id=20,
+                    channel_name="work-tracker",
+                    logged_by=30,
+                )
+                self.assertFalse(duplicate["created"])
+                active = await store.list_items("active")
+                self.assertEqual(len(active), 1)
+                self.assertEqual(active[0]["priority"], "p1")
+                done = await store.set_item_status(active[0]["id"], "done", local_date="2026-05-02")
+                self.assertIsNotNone(done)
+                self.assertEqual(done["status"], "done")
+                self.assertTrue((root / "data" / "work" / "2026-05-02.jsonl").exists())
+                state = (root / "state" / "work.md").read_text(encoding="utf-8")
+                self.assertIn("# Work State", state)
+
+        asyncio.run(run_case())
+
+    def test_focus_and_search_context(self) -> None:
+        async def run_case() -> None:
+            with tempfile.TemporaryDirectory() as tempdir:
+                root = Path(tempdir)
+                (root / "wiki" / "domains").mkdir(parents=True)
+                (root / "wiki" / "domains" / "work.md").write_text("Important client onboarding checklist", encoding="utf-8")
+                store = WorkStore(root / "tracker.db", root)
+                await store.init()
+                drafts = [parse_work_item("urgent unblock client onboarding today", today=date(2026, 5, 2))]
+                await store.log_work_message(
+                    local_date="2026-05-02",
+                    raw_text=drafts[0].raw_text,
+                    drafts=drafts,
+                    message_id=None,
+                    channel_id=None,
+                    channel_name="work-tracker",
+                    logged_by=None,
+                )
+                focus_text = await store.build_focus_text("2026-05-02")
