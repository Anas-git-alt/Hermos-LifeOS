+++ b/apps/discord_tracker/work_store.py
@@ -0,0 +1,600 @@
+from __future__ import annotations
+
+import json
+import sqlite3
+from datetime import date, datetime, timedelta, timezone
+from pathlib import Path
+from typing import Any
+
+from work import WorkItemDraft, priority_rank, render_focus_plan
+
+
+OPEN_STATUSES = ("open", "waiting", "blocked")
+
+
+class WorkStore:
+    """Work assistant storage integrated with the existing Life OS tracker DB.
+
+    This deliberately uses the same SQLite database and filesystem convention as
+    prayer/hydration/finance, but keeps work tables isolated so it can be added
+    without rewriting the existing TrackerStore.
+    """
+
+    def __init__(self, db_path: Path, lifeos_root: Path):
+        self.db_path = Path(db_path)
+        self.lifeos_root = Path(lifeos_root)
+        self.work_dir = self.lifeos_root / "data" / "work"
+        self.raw_capture_dir = self.lifeos_root / "raw" / "captures"
+        self.state_dir = self.lifeos_root / "state"
+        self.report_dir = self.lifeos_root / "reports" / "work"
+
+    async def init(self) -> None:
+        self.db_path.parent.mkdir(parents=True, exist_ok=True)
+        self.work_dir.mkdir(parents=True, exist_ok=True)
+        self.raw_capture_dir.mkdir(parents=True, exist_ok=True)
+        self.state_dir.mkdir(parents=True, exist_ok=True)
+        self.report_dir.mkdir(parents=True, exist_ok=True)
+        with self._connect() as db:
+            db.executescript(
+                """
+                CREATE TABLE IF NOT EXISTS work_items (
+                    id INTEGER PRIMARY KEY AUTOINCREMENT,
+                    title TEXT NOT NULL,
+                    status TEXT NOT NULL,
+                    priority TEXT NOT NULL,
+                    project TEXT,
+                    area TEXT,
+                    due_date TEXT,
+                    energy TEXT,
+                    effort_minutes INTEGER,
+                    context TEXT,
+                    tags_json TEXT NOT NULL,
+                    note TEXT,
+                    confidence TEXT NOT NULL,
+                    source TEXT NOT NULL,
+                    source_message_id INTEGER,
+                    source_channel_id INTEGER,
+                    logged_by INTEGER,
+                    raw_text TEXT NOT NULL,
+                    source_item_index INTEGER NOT NULL DEFAULT 0,
+                    created_at_utc TEXT NOT NULL,
+                    updated_at_utc TEXT NOT NULL,
+                    completed_at_utc TEXT,
+                    UNIQUE(source, source_message_id, source_item_index)
+                );
+
+                CREATE TABLE IF NOT EXISTS work_events (
+                    id INTEGER PRIMARY KEY AUTOINCREMENT,
+                    item_id INTEGER,
+                    event TEXT NOT NULL,
+                    payload_json TEXT NOT NULL,
+                    local_date TEXT NOT NULL,
+                    created_at_utc TEXT NOT NULL
+                );
+
+                CREATE TABLE IF NOT EXISTS work_improvements (
+                    id INTEGER PRIMARY KEY AUTOINCREMENT,
+                    idea TEXT NOT NULL,
+                    status TEXT NOT NULL,
+                    impact TEXT,
+                    effort TEXT,
+                    source TEXT NOT NULL,
+                    source_message_id INTEGER,
+                    source_channel_id INTEGER,
+                    logged_by INTEGER,
+                    created_at_utc TEXT NOT NULL,
+                    updated_at_utc TEXT NOT NULL
+                );
+                """
+            )
+            db.commit()
+        await self.write_state_snapshot()
+
+    def _connect(self) -> sqlite3.Connection:
+        con = sqlite3.connect(self.db_path)
+        con.row_factory = sqlite3.Row
+        return con
+
+    async def log_work_message(
+        self,
+        *,
+        local_date: str,
+        raw_text: str,
+        drafts: list[WorkItemDraft],
+        message_id: int | None,
+        channel_id: int | None,
+        channel_name: str,
+        logged_by: int | None,
+        source: str = "discord",
+    ) -> dict[str, Any]:
+        if not drafts:
+            return {"status": "ignored", "created": False, "item_ids": []}
+        with self._connect() as db:
+            duplicate = _work_duplicate(db, source, message_id)
+            if duplicate:
+                return {"status": "duplicate", "created": False, "item_ids": duplicate}
+
+            now = utc_now_iso()
+            item_ids: list[int] = []
+            records: list[dict[str, Any]] = []
+            for index, draft in enumerate(drafts):
+                item_id = _insert_work_item(
+                    db,
+                    draft=draft,
+                    raw_text=raw_text,
+                    source=source,
+                    message_id=message_id,
+                    source_item_index=index,
+                    channel_id=channel_id,
+                    logged_by=logged_by,
+                    now=now,
+                )
+                item_ids.append(item_id)
+                record = _work_record(
+                    item_id=item_id,
+                    draft=draft,
+                    raw_text=raw_text,
+                    source=source,
+                    message_id=message_id,
+                    source_item_index=index,
+                    channel_id=channel_id,
+                    logged_by=logged_by,
+                    event="work_item_created",
+                    now=now,
+                )
+                _insert_work_event(db, item_id, "created", record, local_date, now)
+                records.append(record)
+            db.commit()
+
+        for record in records:
+            await self._append_daily_logs(local_date, record, _work_md_row(record))
+        self._append_raw_work_capture(local_date, utc_now_iso(), source, channel_name, message_id, raw_text)
+        await self.write_state_snapshot()
+        return {"status": "created", "created": True, "item_ids": item_ids}
+
+    async def list_items(self, status: str = "open", limit: int = 12) -> list[dict[str, Any]]:
+        if status == "active":
+            where = "status IN ('open', 'waiting', 'blocked')"
+            params: tuple[Any, ...] = ()
+        else:
+            where = "status = ?"
+            params = (status,)
+        with self._connect() as db:
+            rows = db.execute(
+                f"""
+                SELECT * FROM work_items
+                WHERE {where}
+                ORDER BY
+                    CASE status WHEN 'blocked' THEN 0 WHEN 'waiting' THEN 1 ELSE 2 END,
+                    CASE priority WHEN 'p0' THEN 0 WHEN 'p1' THEN 1 WHEN 'p2' THEN 2 ELSE 3 END,
+                    CASE WHEN due_date IS NULL THEN 1 ELSE 0 END,
+                    due_date ASC,
+                    created_at_utc ASC
+                LIMIT ?
+                """,
+                (*params, limit),
+            ).fetchall()
+        return [_row_to_item(row) for row in rows]
+
+    async def focus_items(self, local_date: str, limit: int = 5) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
+        today = date.fromisoformat(local_date)
+        soon = (today + timedelta(days=2)).isoformat()
+        with self._connect() as db:
+            focus_rows = db.execute(
+                """
+                SELECT * FROM work_items
+                WHERE status = 'open'
+                  AND (priority IN ('p0', 'p1') OR due_date <= ?)
+                ORDER BY
+                    CASE priority WHEN 'p0' THEN 0 WHEN 'p1' THEN 1 WHEN 'p2' THEN 2 ELSE 3 END,
+                    CASE WHEN due_date IS NULL THEN 1 ELSE 0 END,
+                    due_date ASC,
+                    COALESCE(effort_minutes, 999) ASC,
+                    created_at_utc ASC
+                LIMIT ?
+                """,
+                (soon, limit),
+            ).fetchall()
+            blocked_rows = db.execute(
+                """
+                SELECT * FROM work_items
+                WHERE status IN ('blocked', 'waiting')
+                ORDER BY updated_at_utc DESC
+                LIMIT 5
+                """
+            ).fetchall()
+        focus = [_row_to_item(row) for row in focus_rows]
+        if len(focus) < limit:
+            more = await self.list_items("open", limit=limit * 2)
+            seen = {item["id"] for item in focus}
+            for item in more:
+                if item["id"] not in seen:
+                    focus.append(item)
+                    seen.add(item["id"])
+                if len(focus) >= limit:
+                    break
+        return focus, [_row_to_item(row) for row in blocked_rows]
+
+    async def build_focus_text(self, local_date: str, limit: int = 5) -> str:
+        focus, blocked = await self.focus_items(local_date, limit)
+        return render_focus_plan(local_date, focus, blocked)
+
+    async def set_item_status(
+        self,
+        item_id: int,
+        status: str,
+        *,
+        local_date: str,
+        note: str = "",
+        logged_by: int | None = None,
+    ) -> dict[str, Any] | None:
+        if status not in {"open", "waiting", "blocked", "done", "cancelled"}:
+            raise ValueError(f"Unsupported work status: {status}")
+        now = utc_now_iso()
+        completed_at = now if status == "done" else None
+        with self._connect() as db:
+            row = db.execute("SELECT * FROM work_items WHERE id = ?", (item_id,)).fetchone()
+            if row is None:
+                return None
+            db.execute(
+                """
+                UPDATE work_items
+                SET status = ?, note = ?, updated_at_utc = ?, completed_at_utc = COALESCE(?, completed_at_utc)
+                WHERE id = ?
+                """,
+                (status, note or row["note"], now, completed_at, item_id),
+            )
+            updated = db.execute("SELECT * FROM work_items WHERE id = ?", (item_id,)).fetchone()
+            item = _row_to_item(updated)
+            payload = {"event": f"work_item_{status}", "id": item_id, "status": status, "note": note, "logged_by": logged_by, **item}
+            _insert_work_event(db, item_id, status, payload, local_date, now)
+            db.commit()
+        await self._append_daily_logs(local_date, payload, _work_md_row(payload))
+        await self.write_state_snapshot()
+        return item
+
+    async def add_improvement(
+        self,
+        *,
+        idea: str,
+        local_date: str,
+        source: str,
+        message_id: int | None,
+        channel_id: int | None,
+        logged_by: int | None,
+    ) -> int:
+        now = utc_now_iso()
+        with self._connect() as db:
+            cur = db.execute(
+                """
+                INSERT INTO work_improvements
+                    (idea, status, impact, effort, source, source_message_id, source_channel_id,
+                     logged_by, created_at_utc, updated_at_utc)
+                VALUES (?, 'open', NULL, NULL, ?, ?, ?, ?, ?, ?)
+                """,
+                (idea.strip(), source, message_id, channel_id, logged_by, now, now),
+            )
+            improvement_id = int(cur.lastrowid)
+            payload = {"event": "work_improvement", "id": improvement_id, "idea": idea.strip(), "status": "open"}
+            _insert_work_event(db, None, "improvement", payload, local_date, now)
+            db.commit()
+        await self._append_daily_logs(local_date, payload, _work_md_row(payload))
+        return improvement_id
+
+    async def daily_review(self, local_date: str) -> str:
+        today = date.fromisoformat(local_date)
+        with self._connect() as db:
+            completed = db.execute(
+                "SELECT COUNT(*) FROM work_items WHERE date(completed_at_utc) = ?",
+                (local_date,),
+            ).fetchone()[0]
+            open_count = db.execute(
+                "SELECT COUNT(*) FROM work_items WHERE status = 'open'",
+            ).fetchone()[0]
+            blocked_count = db.execute(
+                "SELECT COUNT(*) FROM work_items WHERE status IN ('blocked', 'waiting')",
+            ).fetchone()[0]
+            overdue = db.execute(
+                "SELECT COUNT(*) FROM work_items WHERE status = 'open' AND due_date < ?",
+                (today.isoformat(),),
+            ).fetchone()[0]
+        focus, blocked = await self.focus_items(local_date, 5)
+        report = [
+            f"# Work Review - {local_date}",
+            "",
+            "## Metrics",
+            f"- Completed today: {completed}",
+            f"- Open items: {open_count}",
+            f"- Blocked/waiting: {blocked_count}",
+            f"- Overdue: {overdue}",
+            "",
+            "## Tomorrow / Next Focus",
+        ]
+        if focus:
+            for item in focus:
+                report.append(f"- {item['priority'].upper()} #{item['id']} {item['title']}")
+        else:
+            report.append("- No open focus items.")
+        if blocked:
+            report.extend(["", "## Blocked / Waiting"])
+            for item in blocked:
+                report.append(f"- #{item['id']} {item['title']} ({item['status']})")
+        report.extend([
+            "",
+            "## Continuous Improvement Prompt",
+            "- What wasted the most time today?",
+            "- What should be automated, templated, delegated, or clarified before tomorrow?",
+            "",
+        ])
+        output = self.report_dir / f"{local_date}.md"
+        output.parent.mkdir(parents=True, exist_ok=True)
+        output.write_text("\n".join(report), encoding="utf-8")
+        return str(output.relative_to(self.lifeos_root))
+
+    async def search_context(self, query: str, limit: int = 5) -> list[dict[str, Any]]:
+        tokens = [token.lower() for token in query.split() if len(token) >= 2]
+        if not tokens:
+            return []
+        roots = [
+            self.lifeos_root / "wiki",
+            self.lifeos_root / "state",
+            self.lifeos_root / "reports",
+            self.lifeos_root / "memory" / "curated",
+            self.lifeos_root / "data" / "daily-summary",
+            self.lifeos_root / "data" / "work",
+        ]
+        results: list[dict[str, Any]] = []
+        for root in roots:
+            if not root.exists():
+                continue
+            for path in root.rglob("*.md"):
+                if path.stat().st_size > 200_000:
+                    continue
+                try:
+                    lines = path.read_text(encoding="utf-8").splitlines()
+                except UnicodeDecodeError:
+                    continue
+                for line_no, line in enumerate(lines, start=1):
+                    lower = line.lower()
+                    score = sum(1 for token in tokens if token in lower)
+                    if score == 0:
+                        continue
+                    rel = str(path.relative_to(self.lifeos_root))
+                    snippet = line.strip()
+                    if len(snippet) > 180:
+                        snippet = snippet[:177] + "..."
+                    results.append({"path": rel, "line": line_no, "snippet": snippet, "score": score})
+        results.sort(key=lambda item: (-item["score"], item["path"], item["line"]))
+        return results[:limit]
+
+    async def write_state_snapshot(self) -> None:
+        if not self.db_path.exists():
+            return
+        active = await self.list_items("active", limit=50)
+        now_items = [item for item in active if item["status"] == "open" and item["priority"] in {"p0", "p1"}]
+        next_items = [item for item in active if item["status"] == "open" and item["priority"] not in {"p0", "p1"}]
+        blocked = [item for item in active if item["status"] in {"blocked", "waiting"}]
+
+        lines = [
+            "# Work State",
+            "",
+            f"Generated: {utc_now_iso()}",
+            "Source: tracker DB work_items + data/work daily logs",
+            "",
+            "## Now",
+        ]
+        lines.extend(_state_lines(now_items[:10]))
+        lines.extend(["", "## Next"])
+        lines.extend(_state_lines(next_items[:20]))
+        lines.extend(["", "## Blocked / Waiting"])
+        lines.extend(_state_lines(blocked[:20]))
+        lines.extend([
+            "",
+            "## Operating Rules",
+            "- Prefer one P0/P1 item in progress at a time.",
+            "- Blocked items need a named next unblock action.",
+            "- Capture recurring friction with `!work improve <idea>`.",
+            "",
+        ])
+        (self.state_dir / "work.md").write_text("\n".join(lines), encoding="utf-8")
+
+    async def _append_daily_logs(self, local_date: str, record: dict[str, Any], markdown_row: str) -> None:
+        jsonl_path = self.work_dir / f"{local_date}.jsonl"
+        md_path = self.work_dir / f"{local_date}.md"
+        _append_text(jsonl_path, json.dumps(record, sort_keys=True, ensure_ascii=False) + "\n")
+        if not md_path.exists():
+            _append_text(md_path, _md_header(local_date))
+        _append_text(md_path, markdown_row)
+
+    def _append_raw_work_capture(
+        self,
+        local_date: str,
+        timestamp_utc: str,
+        source: str,
+        channel_name: str,
+        message_id: int | None,
+        raw_text: str,
+    ) -> None:
+        capture_id = f"work-{source}-{message_id or timestamp_utc.replace(':', '').replace('+', '')}"
+        block = (
+            "\n---\n\n"
+            f"capture_id: {capture_id}\n"
+            f"timestamp: {timestamp_utc}\n"
+            f"source: {source}:#{channel_name}\n"
+            "classification: task\n"
+            "status: work_structured\n"
+            "processed: true\n\n"
+            f"{raw_text}\n"
+        )
+        _append_text(self.raw_capture_dir / f"{local_date}.md", block)
+
+
+def utc_now_iso() -> str:
+    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()
+
+
+def _insert_work_item(
+    db: sqlite3.Connection,
+    *,
+    draft: WorkItemDraft,
+    raw_text: str,
+    source: str,
+    message_id: int | None,
+    source_item_index: int,
+    channel_id: int | None,
+    logged_by: int | None,
+    now: str,
+) -> int:
+    cur = db.execute(
+        """
+        INSERT INTO work_items
+            (title, status, priority, project, area, due_date, energy, effort_minutes,
+             context, tags_json, note, confidence, source, source_message_id,
+             source_channel_id, logged_by, raw_text, source_item_index, created_at_utc,
+             updated_at_utc)
+        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+        """,
+        (
+            draft.title,
+            draft.status,
+            draft.priority,
+            draft.project,
+            draft.area,
+            draft.due_date,
+            draft.energy,
+            draft.effort_minutes,
+            draft.context,
+            json.dumps(list(draft.tags), sort_keys=True),
+            draft.note,
+            draft.confidence,
+            source,
+            message_id,
+            channel_id,
+            logged_by,
+            raw_text,
+            source_item_index,
+            now,
+            now,
+        ),
+    )
+    return int(cur.lastrowid)
+
+
+def _insert_work_event(db: sqlite3.Connection, item_id: int | None, event: str, payload: dict[str, Any], local_date: str, now: str) -> None:
+    db.execute(
+        """
+        INSERT INTO work_events (item_id, event, payload_json, local_date, created_at_utc)
+        VALUES (?, ?, ?, ?, ?)
+        """,
+        (item_id, event, json.dumps(payload, sort_keys=True, ensure_ascii=False), local_date, now),
+    )
+
+
+def _work_duplicate(db: sqlite3.Connection, source: str, message_id: int | None) -> list[int] | None:
+    if message_id is None:
+        return None
+    rows = db.execute(
+        """
+        SELECT id FROM work_items
+        WHERE source = ? AND source_message_id = ?
+        ORDER BY source_item_index, id
+        """,
+        (source, message_id),
+    ).fetchall()
+    if not rows:
+        return None
+    return [int(row[0]) for row in rows]
+
+
+def _work_record(
+    *,
+    item_id: int,
+    draft: WorkItemDraft,
+    raw_text: str,
+    source: str,
+    message_id: int | None,
+    source_item_index: int,
+    channel_id: int | None,
+    logged_by: int | None,
+    event: str,
+    now: str,
+) -> dict[str, Any]:
+    return {
+        "event": event,
+        "id": item_id,
+        "title": draft.title,
+        "status": draft.status,
+        "priority": draft.priority,
+        "project": draft.project,
+        "area": draft.area,
+        "due_date": draft.due_date,
+        "energy": draft.energy,
+        "effort_minutes": draft.effort_minutes,
+        "context": draft.context,
+        "tags": list(draft.tags),
+        "note": draft.note,
+        "confidence": draft.confidence,
+        "raw_text": raw_text,
+        "source": source,
+        "source_message_id": message_id,
+        "source_item_index": source_item_index,
+        "source_channel_id": channel_id,
+        "logged_by": logged_by,
+        "created_at_utc": now,
+        "updated_at_utc": now,
+    }
+
+
+def _row_to_item(row: sqlite3.Row) -> dict[str, Any]:
+    item = dict(row)
+    try:
+        item["tags"] = json.loads(item.pop("tags_json") or "[]")
+    except json.JSONDecodeError:
+        item["tags"] = []
+    return item
+
+
+def _work_md_row(record: dict[str, Any]) -> str:
+    event = record.get("event", "work_event")
+    timestamp = record.get("updated_at_utc") or record.get("created_at_utc") or utc_now_iso()
+    title = str(record.get("title") or record.get("idea") or record.get("note") or "").replace("|", "\\|")
+    item_id = record.get("id", "")
+    priority = record.get("priority", "")
+    status = record.get("status", "")
+    project = (record.get("project") or "").replace("|", "\\|")
+    due = record.get("due_date") or ""
+    return f"| {timestamp} | {event} | {item_id} | {priority} | {status} | {title} | {project} | {due} |\n"
+
+
+def _md_header(local_date: str) -> str:
+    return (
+        f"# Work Log {local_date}\n\n"
+        "| Time (UTC) | Event | ID | Priority | Status | Title | Project | Due |\n"
+        "|---|---|---:|---|---|---|---|---|\n"
+    )
+
+
+def _state_lines(items: list[dict[str, Any]]) -> list[str]:
+    if not items:
+        return ["- none"]
+    ordered = sorted(
+        items,
+        key=lambda item: (
+            priority_rank(item.get("priority", "p2")),
+            item.get("due_date") or "9999-99-99",
+            item.get("created_at_utc") or "",
+        ),
+    )
+    lines = []
+    for item in ordered:
+        due = f" due {item['due_date']}" if item.get("due_date") else ""
+        project = f" project:{item['project']}" if item.get("project") else ""
+        status = f" status:{item['status']}" if item.get("status") != "open" else ""
+        lines.append(f"- #{item['id']} [{item.get('priority', 'p2').upper()}]{due}{project}{status} — {item['title']}")
+    return lines
+
+
+def _append_text(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with path.open("a", encoding="utf-8") as handle:
+        handle.write(text)
